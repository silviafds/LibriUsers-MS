    {
      "name": "Login Libri MS",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Isso vai rodar APÓS receber a resposta do login\r",
              "if (pm.response.code === 200) {\r",
              "    var jsonData = pm.response.json();\r",
              "\r",
              "    // Salva o token como variável global\r",
              "    pm.globals.set(\"tokenLibri\", jsonData.token);\r",
              "\r",
              "    // Ou se o token vier em outro campo:\r",
              "    // pm.globals.set(\"tokenLibri\", jsonData.access_token);\r",
              "    // pm.globals.set(\"tokenLibri\", jsonData.data.token);\r",
              "\r",
              "    console.log(\"Token salvo: \" + jsonData.token);\r",
              "} else {\r",
              "    console.log(\"Login falhou\");\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
